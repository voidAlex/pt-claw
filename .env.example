# ── qBittorrent ────────────────────────────────────
QBITTORRENT_URL=http://<host>:<port>
QBITTORRENT_USER=<username>
QBITTORRENT_PASS=<password>

# ── M-Team API ─────────────────────────────────────
MTEAM_API_KEY=<your-api-key>

# ── PT Site Cookies ────────────────────────────────
# 从浏览器 DevTools → Application → Cookies 复制
# 格式: key1=val1; key2=val2; ...
PT_COOKIE_PTTIME=<cookie-string>
PT_COOKIE_BTSCHOOL=<cookie-string>
PT_COOKIE_CARPT=<cookie-string>
PT_COOKIE_HDFANS=<cookie-string>
PT_COOKIE_1PTBA=<cookie-string>
PT_COOKIE_SOULVOICE=<cookie-string>
PT_COOKIE_ZMPT=<cookie-string>

# ── Jellyfin (可选) ────────────────────────────────
JELLYFIN1_URL=http://<host>:8096
JELLYFIN1_API_KEY=<api-key>
JELLYFIN2_URL=http://<host>:8096
JELLYFIN2_API_KEY=<api-key>

# ── 代理 (可选) ────────────────────────────────────
# HTTP_PROXY=http://<host>:<port>
# HTTPS_PROXY=http://<host>:<port>
