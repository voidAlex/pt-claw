# qBittorrent
QBITTORRENT_URL=<QB_HOST>
QBITTORRENT_USER=<QB_USER>
QBITTORRENT_PASS=<QB_PASS>
# QB_CLEANUP_DRY_RUN=1  # optional: public cleanup dry-run mode (report only, no delete)

# Jellyfin
